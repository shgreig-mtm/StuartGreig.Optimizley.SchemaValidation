<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AddRazorSupportForMvc>true</AddRazorSupportForMvc>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <PackageId>SchemaInspector.Optimizely</PackageId>
    <Version>1.0.0</Version>
    <Authors>Your Name</Authors>
    <Description>Schema.org Inspector add-on for Optimizely CMS 13</Description>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="EPiServer.CMS.UI.Core" Version="13.0.0" />
    <PackageReference Include="EPiServer.CMS.Core" Version="13.0.0" />
    <PackageReference Include="EPiServer.Framework" Version="13.0.0" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="module.config" />
    <EmbeddedResource Include="ClientResources\**\*" />
  </ItemGroup>

  <ItemGroup>
    <Content Update="wwwroot\**\*" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="Components\" />
  </ItemGroup>

</Project>
